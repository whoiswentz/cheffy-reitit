# Copy to .env and fill in real values (.env is gitignored).
# environ reads system environment variables, not .env files directly —
# load it with `export $(grep -v '^#' .env | xargs)` or use direnv.
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_TEST_USERNAME=testing@cheffy.app
AUTH0_TEST_PASSWORD=your-test-user-password
